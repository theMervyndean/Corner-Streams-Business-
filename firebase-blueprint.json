        "isRegisteredYetToUpdate": { "type": "boolean" },
        "username": { "type": "string" },
        "motto": { "type": "string" },
        "logoUrl": { "type": "string" },
        "isRegisteredCAC": { "type": "boolean" },
        "cacDocumentImage": { "type": "string" },
        "personalIdType": { "type": "string" },
        "personalIdImage": { "type": "string" }
      },
      "required": ["id", "businessName", "ownerName", "email", "password"]
    }
  },
  "firestore": {
    "/shops/{shopId}": {
      "schema": "ShopOwner",
      "description": "Stores individual shop owners data, including their nested products, logs, and billing details."
    }
