        "id": { "type": "string" },
        "businessName": { "type": "string" },
        "ownerName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "password": { "type": "string" },
        "nin": { "type": "string" },
        "ninVerifiedName": { "type": "string" },
        "ninLookupStatus": { "type": "string" },
        "goodsType": { "type": "string" },
        "selectedPlan": { "type": "string" },
        "cardNumber": { "type": "string" },
        "expiry": { "type": "string" },
        "cvv": { "type": "string" },
        "activePlanType": { "type": "string" },
        "dateRegistered": { "type": "string" },
        "status": { "type": "string" },
        "cumulativeRevenue": { "type": "number" },
        "products": { "type": "array" },
        "staff": { "type": "array" },
        "activities": { "type": "array" },
        "debtors": { "type": "array" },
        "shifts": { "type": "array" },
